{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "build": "node ./build.mjs",
    "build:vercel": "esbuild src/api-entry.ts --bundle --platform=node --format=esm --outfile=dist/api-entry.mjs --external:cookie-parser --external:cors --external:drizzle-orm --external:drizzle-zod --external:express --external:multer --external:pino --external:pino-http --external:zod --external:@libsql/client --external:sql.js",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "db:push": "drizzle-kit push --config ../../lib/db/drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "sql.js": "^1.11.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "esbuild": "0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
