{
  "framework": null,
  "buildCommand": "pnpm --filter @workspace/noka-store run build",
  "outputDirectory": "artifacts/noka-store/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
